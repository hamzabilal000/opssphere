NODE_ENV=development
PORT=4000
WEB_ORIGIN=http://localhost:5173

MONGODB_URI=mongodb://localhost:27017/opssphere

ACCESS_TOKEN_SECRET=replace_me_with_a_long_random_string
REFRESH_TOKEN_SECRET=replace_me_with_a_different_long_random_string
